# Azure Authentication
# Option 1: Service Principal
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_TENANT_ID=your-tenant-id

# Option 2: Use Azure CLI authentication (no env vars needed)
# Run: az login

# Default subscription(s) to scan (comma-separated)
# AZURE_SUBSCRIPTION_IDS=sub-id-1,sub-id-2

# Database URL (SQLite for dev, PostgreSQL for prod)
# DATABASE_URL=sqlite+aiosqlite:///~/.azsla/sla_data.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/azsla

# Web server settings
# HOST=0.0.0.0
# PORT=8000
# DEBUG=false
# LOG_LEVEL=INFO

# Background collection settings
# COLLECTION_ENABLED=true
# COLLECTION_INTERVAL_HOURS=6
# COLLECTION_LOOKBACK_DAYS=1

# Optional: Custom SLA catalog path
# SLA_CATALOG_PATH=./slas/azure_sla_catalog.yaml
